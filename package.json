{
  "name": "utpl-rag-demo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx scripts/build-artifacts.ts",
    "validate:calendar-pdfs": "tsx scripts/validate-calendar-from-pdfs.ts",
    "extract:calendar-vision": "tsx scripts/extract-events-from-pdfs-vision.ts",
    "extract:doop-textract": "tsx --env-file-if-exists=.env scripts/textract-doop-pdfs.ts",
    "bundle:extraccion-utpl-v1": "tsx scripts/bundle-extraccion-utpl-v1.ts",
    "extraccion:utpl-v1": "npm run extract:doop-textract && npm run bundle:extraccion-utpl-v1",
    "extraccion:utpl-v1:force": "npm run extract:doop-textract -- --force && npm run bundle:extraccion-utpl-v1 && npm run process:textract-calendar",
    "process:textract-calendar": "tsx scripts/process-textract-raw-to-calendar.ts",
    "inspect:textract-blocks": "tsx scripts/inspect-textract-blocks.ts",
    "calendar:emit-from-textract": "tsx scripts/emit-calendar-from-textract-candidates.ts",
    "list:doop-duplicates-from-textract": "tsx scripts/list-doop-duplicate-pdfs-from-textract.ts",
    "list:doop-duplicates-from-textract:audit": "tsx scripts/list-doop-duplicate-pdfs-from-textract.ts --audit-json",
    "dedupe:pdf-content": "tsx scripts/pdf-content-dedupe.ts",
    "dedupe:pdf-content:doop": "tsx scripts/pdf-content-dedupe.ts --root=doop --textract-manifest=data/derived/textract-raw/manifest.json --out=data/derived/pdf-content-dedupe.json",
    "extract:utpl-events-json": "tsx --env-file-if-exists=.env scripts/extract-utpl-events-json.ts",
    "calendar:build-high-confidence": "tsx scripts/build-calendar-events-high-confidence.ts",
    "pdf:build-catalog": "tsx scripts/build-doop-pdf-catalog.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vision": "^5.3.6",
    "@google/genai": "^1.17.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.12",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.539.0",
    "next": "^16.1.6",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/client-textract": "^3.787.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.34.0",
    "eslint-config-next": "^16.1.6",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
